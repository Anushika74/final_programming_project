# ============================================================
# SystemIQ backend configuration
# Copy to `.env` and adjust values for your environment.
# ============================================================

# ---- Application ----
APP_NAME=SystemIQ
ENVIRONMENT=development          # development | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database ----
# SQLite (default, dev). PostgreSQL recommended for production:
#   postgresql+psycopg://systemiq:password@localhost:5432/systemiq
DATABASE_URL=sqlite:///./systemiq.db

# ---- Security / JWT ----
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_super_secret_key_please_rotate_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ---- Default bootstrap admin (created on first startup) ----
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@systemiq.io
FIRST_ADMIN_PASSWORD=admin123

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Monitoring ----
METRICS_BROADCAST_INTERVAL=2     # seconds between WebSocket pushes
METRICS_PERSIST_INTERVAL=60      # seconds between DB snapshots
METRICS_RETENTION_DAYS=30        # purge metrics older than this

# ---- Alert thresholds (percent) ----
ALERT_CPU_THRESHOLD=90
ALERT_MEMORY_THRESHOLD=90
ALERT_DISK_THRESHOLD=95

# ---- Email alerts (optional; leave SMTP_HOST empty to disable) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=systemiq@localhost
ALERT_EMAIL_TO=

# ---- ML ----
ML_MODEL_DIR=./ml_models
ML_MIN_TRAINING_SAMPLES=30
# Automatic retraining of saved models from the continuously collected data.
AUTO_RETRAIN_ENABLED=true
AUTO_RETRAIN_INTERVAL_HOURS=24

# ---- Optional LLM provider for the NL assistant ----
# Leave LLM_PROVIDER empty to use the built-in rule-based interpreter.
LLM_PROVIDER=                    # ollama | openai | gemini | (empty)
LLM_MODEL=llama3
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
